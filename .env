# Contact form recipient email
# Replace with your actual email address
VITE_CONTACT_EMAIL=contact@xlchess.com

# -----------------------------------------------------------------------------
# Authentication (Auth.js / @auth/core) Environment Variables
# -----------------------------------------------------------------------------

# Secret key used to encrypt and sign JWT tokens, session state, and cookies.
# Generate a secure secret in production using: openssl rand -base64 33
AUTH_SECRET="YOUR_AUTH_SECRET_PLACEHOLDER_MIN_32_CHARS"

# Base URL of the authentication endpoints.
# During local development on Vite, this is your local server address (usually http://localhost:5173).
AUTH_URL="http://localhost:5173"

# Google OAuth Client Credentials
# Create these in the Google Cloud Console (https://console.cloud.google.com)
# under APIs & Services > Credentials. Configure authorized redirect URIs to include:
# - http://localhost:5173/api/auth/callback/google (development)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-your-google-client-secret"

